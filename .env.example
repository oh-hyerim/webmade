# --- 클라이언트(번들에 포함되는 공개 값만) ---
VITE_PUBLIC_SITE_URL=https://example.com
VITE_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Publishable(구 anon) — 프런트 전용. service_role/secret 키는 넣지 마세요.
VITE_PUBLIC_SUPABASE_ANON_KEY=
# 선택: 새 키 모델 사용 시 (설정 시 위 anon 대신 사용)
# VITE_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# GA4 (선택)
# VITE_GA_MEASUREMENT_ID=

# Sentry 브라우저 DSN (선택, 공개 DSN)
# VITE_SENTRY_DSN=

# 로컬에서만: 배포된 사이트의 검증 API URL (vite 단독 실행 시 /api 없음)
# VITE_REQUEST_VERIFY_URL=https://your-domain.com/api/verify-request-access

# --- Vercel 서버 전용 (프런트 번들에 넣지 않음, Vercel 대시보드에 설정) ---
# REQUEST_ACCESS_TOKEN=계약고객에게만 전달하는 비밀 문자열
